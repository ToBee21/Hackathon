dist/
build/
.plasmo/

# Environment variables
.env
.env.local
.env.*.local

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript cache
*.tsbuildinfo

# Test output
coverage/
test-results/

# Tailwind
.cache/

# Package manager locks (keep only one)
# yarn.lock
# pnpm-lock.yaml

# --- Secrets — NEVER commit (signing keys, env, certs) ---
*.pem
*.key
*.p12
*.pfx
.secrets/
**/.secrets/
*.signed.json
.env
.env.*

# --- Large local model weights (placed/downloaded at build time, not in git) ---
# Keep small tracked assets (e.g. grandma.stl) but ignore multi-GB weight dirs.
/assets/models/*/

# --- Local backups / scratch ---
*.bak.js
*.OLD.*
*.bak

# Distilled-model training build artifacts (large binaries, like model weights)
training/out/
