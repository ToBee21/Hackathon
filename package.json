{
  "name": "cloak-and-dagger",
  "displayName": "Cloak & Dagger",
  "version": "0.1.0",
  "description": "Aktywny system ochrony prywatności i suwerenności danych użytkownika w sieci.",
  "author": "Hackathon Signal:Noise Team",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "^0.89.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@plasmohq/prettier-plugin-sort-imports": "^4.0.1",
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "manifest": {
    "permissions": [
      "storage",
      "browsingData",
      "cookies",
      "alarms"
    ],
    "host_permissions": [
      "<all_urls>"
    ]
  }
