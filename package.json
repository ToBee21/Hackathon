{
  "name": "privacymyst",
  "displayName": "PrivacyMyst",
  "version": "0.1.2",
  "description": "Aktywny system ochrony prywatności i suwerenności danych użytkownika w sieci.",
  "author": "Hackathon Signal:Noise Team",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "demo": "node scripts/launch-demo.mjs",
    "verify:block": "node scripts/verify-tracker-block.mjs",
    "blocklist:compile": "node scripts/compile-blocklists.mjs",
    "blocklist:keygen": "node scripts/compile-blocklists.mjs --keygen",
    "blocklist:sign": "node server/build-bundle.mjs",
    "infer:nli": "node scripts/run-local-nli.mjs",
    "bench:sensitivity": "node scripts/bench-sensitivity.mjs",
    "smoke:extension": "playwright test tests/bionicBlurExtension.spec.ts --reporter=line",
    "test": "vitest run",
    "security:prove": "npm run typecheck && npm run build && vitest run tests/security",
    "security:audit": "vitest run tests/security",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@adguard/hostlist-compiler": "^2.1.0",
    "@plasmohq/prettier-plugin-sort-imports": "^4.0.1",
    "@playwright/test": "^1.60.0",
    "@types/chrome": "^0.0.287",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "plasmo": "^0.90.5",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "alias": {
    "@huggingface/transformers": "@huggingface/transformers/dist/transformers.web.js"
  },
  "manifest": {
    "permissions": [
      "storage",
      "browsingData",
      "cookies",
      "history",
      "alarms",
      "tabs",
      "debugger",
      "scripting",
      "privacy",
      "downloads",
      "declarativeNetRequest",
      "declarativeNetRequestFeedback",
      "sidePanel",
      "contextMenus",
      "offscreen"
    ],
    "commands": {
      "scan-ad-images": {
        "suggested_key": {
          "default": "Alt+Shift+V"
        },
        "description": "PrivacyMyst: skanuj reklamy-obrazki na stronie (AI vision)"
      }
    },
    "host_permissions": [
      "http://*/*",
      "https://*/*"
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
    },
    "web_accessible_resources": [
      {
        "resources": [
          "assets/onnxruntime/*",
          "assets/offscreen/*",
          "assets/vision/*",
          "assets/models/*",
          "assets/models/*/*",
          "assets/models/*/onnx/*",
          "assets/vendor/*"
        ],
        "matches": [
          "http://*/*",
          "https://*/*"
        ]
      }
    ]
  }
}
